# ConnectVeiculos - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# JWT - OBRIGATÓRIO em produção
# Gere uma chave segura com: openssl rand -base64 64
JWT_SECRET_KEY=sua_chave_secreta_muito_segura_aqui_minimo_32_caracteres

# Banco de Dados - PostgreSQL (produção)
DATABASE_URL=postgresql://usuario:senha@host:5432/connectveiculos

# Email (opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app
SMTP_SENDER_EMAIL=noreply@connectveiculos.com.br

# Redis Cache (opcional)
REDIS_CONNECTION_STRING=localhost:6379

# Ambiente
ASPNETCORE_ENVIRONMENT=Production

# CORS - URLs permitidas (separadas por vírgula)
ALLOWED_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com
