# ====================================================================
# ConnectVeiculos - Variaveis de ambiente para producao
# ====================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commitar o .env preenchido no git.
# Gerar JWT secret: openssl rand -base64 64
# ====================================================================

# --- JWT (obrigatorio em prod) ---
JWT_SECRET_KEY=SuaChaveSecretaDevAqui2024!@#$%
JWT_SECRET_KEY_CLIENTE=SuaChaveSecretaClienteAqui2024!@#$%

# --- Mercado Livre ---
# Crie a app em https://developers.mercadolivre.com.br e cole AppId/ClientSecret aqui (ou no .env real)
ML_APP_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://connectveiculos.dev.br/api/integracoes/mercadolivre/callback

# --- CORS (separado por virgula) ---
ALLOWED_ORIGINS=https://connectveiculos.dev.br,https://www.connectveiculos.dev.br

# --- URLs publicas (SEO + feeds de marketplace) ---
# PUBLIC_SITE_URL: fallback usado pelo backend ao gerar links de produto
# para Google Merchant / Facebook Catalog quando Loja.LojUrlCatalogo
# estiver vazio ou invalido. Sem isso, o feed pode publicar links
# quebrados tipo "http:/catalogo/..." que o Merchant Center rejeita.
PUBLIC_SITE_URL=https://connectveiculos.dev.br
# SITE_BASE_URL: usado pelo SSR (server.ts) ao montar sitemap.xml. Deixe
# VAZIO em multi-tenant para que cada subdomain gere sitemap com URL
# propria (server.ts usa o Host header). Setar valor fixo aqui sobrescreve
# o fallback e e necessario quando rodando atras de proxy sem trust-proxy.
SITE_BASE_URL=

# --- Email (opcional) ---
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=587
EMAIL_SENDER_EMAIL=
EMAIL_USERNAME=
EMAIL_PASSWORD=

# --- Facebook Catalog (preencher quando configurar) ---
FB_ACCESS_TOKEN=
FB_CATALOG_ID=

# --- Google Merchant (preencher quando configurar) ---
GOOGLE_MERCHANT_CLIENT_ID=
GOOGLE_MERCHANT_CLIENT_SECRET=
GOOGLE_MERCHANT_REFRESH_TOKEN=
GOOGLE_MERCHANT_ID=
